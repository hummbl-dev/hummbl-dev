{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hummbl-dev/hummbl-dev/docs/durable-intelligence-doctrine/v0.1/schema.json",
  "title": "Agent Session Receipt v0.1",
  "description": "Versioned receipt schema for the Durable Intelligence Doctrine. Every meaningful agent session leaves behind a compact, durable state transition.",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "source_agent",
    "environment",
    "tools_available",
    "repository_or_system_scope",
    "starting_state",
    "actions_attempted",
    "mutations_made",
    "claims",
    "decisions",
    "negative_knowledge",
    "open_questions",
    "next_actions",
    "authority_boundaries",
    "receipt_destination",
    "completion_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "session_id": { "type": "string", "minLength": 1 },
    "source_agent": { "type": "string", "minLength": 1 },
    "environment": { "type": "string", "minLength": 1 },
    "tools_available": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tool_declaration" }
    },
    "repository_or_system_scope": { "type": "string", "minLength": 1 },
    "starting_state": { "type": "string", "minLength": 1 },
    "actions_attempted": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mutations_made": { "$ref": "#/$defs/mutations" },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "decisions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "negative_knowledge": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/next_action" }
    },
    "authority_boundaries": { "$ref": "#/$defs/authority_boundaries" },
    "receipt_destination": { "$ref": "#/$defs/receipt_destination" },
    "completion_status": { "$ref": "#/$defs/completion_status" }
  },
  "$defs": {
    "tool_category": {
      "enum": [
        "shell",
        "filesystem",
        "network",
        "connector",
        "browser",
        "test_runner",
        "deployment",
        "write_access",
        "git",
        "coordination_bus",
        "durable_memory",
        "artifact_creation"
      ]
    },
    "tool_declaration": {
      "type": "object",
      "required": ["category", "available"],
      "additionalProperties": false,
      "properties": {
        "category": { "$ref": "#/$defs/tool_category" },
        "available": { "type": "boolean" }
      }
    },
    "mutation_record": {
      "type": "object",
      "required": ["type", "created"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["branch", "commit", "pr", "issue", "file", "deployment", "other"]
        },
        "created": { "type": "boolean" },
        "identifier": { "type": "string" },
        "locator": { "type": "string" }
      }
    },
    "mutations": {
      "type": "object",
      "required": ["records"],
      "additionalProperties": false,
      "properties": {
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/mutation_record" }
        },
        "summary": { "type": "string" }
      }
    },
    "claim_posture": {
      "enum": [
        "observed",
        "source-reported",
        "inferred",
        "provisional",
        "verified",
        "refuted",
        "unresolved"
      ]
    },
    "claim": {
      "type": "object",
      "required": ["statement", "posture"],
      "additionalProperties": false,
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "posture": { "$ref": "#/$defs/claim_posture" },
        "evidence": { "type": "string" }
      }
    },
    "next_action": {
      "type": "object",
      "required": ["action", "disposition"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "disposition": {
          "enum": ["CONFIRMED", "REFUTED", "INCONCLUSIVE", "BLOCKED_MISSING_AUTHORITY", "SUPERSEDED"]
        },
        "owner": { "type": "string" }
      }
    },
    "authority_boundaries": {
      "type": "object",
      "required": ["scope"],
      "additionalProperties": false,
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "receipt_destination": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["github_issue", "github_pr_comment", "receipt_directory", "claim_evidence_ledger", "task_registry", "handoff_index"]
        },
        "locator": { "type": "string" }
      }
    },
    "completion_status": {
      "enum": ["complete", "in_progress", "blocked", "abandoned"]
    }
  }
}
