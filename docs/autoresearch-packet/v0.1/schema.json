{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hummbl-dev/hummbl-dev/docs/autoresearch-packet/v0.1/schema.json",
  "title": "Autoresearch Packet v0.1",
  "description": "Candidate schema for a governed experiment loop packet: modify, measure, keep/discard, repeat.",
  "type": "object",
  "required": [
    "packet_version",
    "packet_id",
    "title",
    "status",
    "objective",
    "measurement",
    "scope",
    "budget",
    "ledgers",
    "safety",
    "fact_posture"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_version": { "const": "0.1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "$ref": "#/$defs/packet_status" },
    "objective": { "$ref": "#/$defs/objective" },
    "measurement": { "$ref": "#/$defs/measurement" },
    "scope": { "$ref": "#/$defs/scope" },
    "budget": { "$ref": "#/$defs/budget" },
    "ledgers": { "$ref": "#/$defs/ledgers" },
    "safety": { "$ref": "#/$defs/safety" },
    "fact_posture": { "$ref": "#/$defs/fact_posture_enum" },
    "receipts": { "type": "array", "items": { "$ref": "#/$defs/receipt" } },
    "review": { "$ref": "#/$defs/review" },
    "crosswalk_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "packet_status": {
      "enum": ["candidate", "active", "deprecated", "superseded"]
    },
    "fact_posture_enum": {
      "enum": [
        "public_source_fact",
        "local_execution_fact",
        "user_reported_fact",
        "candidate_claim",
        "derived_synthesis",
        "deprecated_or_superseded"
      ]
    },
    "metric_direction": {
      "enum": ["minimize", "maximize"]
    },
    "objective": {
      "type": "object",
      "required": ["metric_name", "metric_direction", "description"],
      "additionalProperties": false,
      "properties": {
        "metric_name": { "type": "string", "minLength": 1 },
        "metric_direction": { "$ref": "#/$defs/metric_direction" },
        "description": { "type": "string", "minLength": 1 },
        "program_md_path": { "type": "string" },
        "objective_config_path": { "type": "string" }
      }
    },
    "measurement": {
      "type": "object",
      "required": ["command", "deterministic"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "deterministic": { "type": "boolean" },
        "evaluator_path": { "type": "string" },
        "metric_extraction": { "type": "string" },
        "seed_control": { "type": "boolean" }
      }
    },
    "scope": {
      "type": "object",
      "required": ["editable", "readonly"],
      "additionalProperties": false,
      "properties": {
        "editable": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "readonly": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "immutable": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "budget": {
      "type": "object",
      "required": ["type", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["time_seconds", "step_count", "cost_usd", "combined"] },
        "value": { "type": "integer", "minimum": 1 },
        "safety_margin": { "type": "number", "minimum": 1 },
        "step_budget": { "type": "integer", "minimum": 1 },
        "time_budget_seconds": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "time_seconds" } } },
          "then": { "required": ["time_budget_seconds"] }
        },
        {
          "if": { "properties": { "type": { "const": "step_count" } } },
          "then": { "required": ["step_budget"] }
        },
        {
          "if": { "properties": { "type": { "const": "combined" } } },
          "then": { "required": ["step_budget", "time_budget_seconds"] }
        }
      ]
    },
    "ledgers": {
      "type": "object",
      "required": ["experiments", "claims"],
      "additionalProperties": false,
      "properties": {
        "experiments": {
          "type": "object",
          "required": ["path", "format"],
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "format": { "enum": ["tsv", "jsonl", "csv", "json"] },
            "append_only": { "type": "boolean" },
            "columns": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "claims": {
          "type": "object",
          "required": ["path", "format"],
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "format": { "enum": ["jsonl", "json", "md"] },
            "append_only": { "type": "boolean" }
          }
        },
        "receipts_dir": { "type": "string" },
        "review_path": { "type": "string" }
      }
    },
    "safety": {
      "type": "object",
      "required": ["autonomy_level", "auto_rollback"],
      "additionalProperties": false,
      "properties": {
        "autonomy_level": {
          "enum": ["bounded", "supervised", "manual"]
        },
        "auto_rollback": { "type": "boolean" },
        "max_changed_lines": { "type": "integer", "minimum": 1 },
        "no_network": { "type": "boolean" },
        "no_new_dependencies": { "type": "boolean" },
        "gpu_preflight": { "type": "boolean" },
        "crash_recovery": { "type": "boolean" },
        "human_review_required": { "type": "boolean" }
      }
    },
    "receipt": {
      "type": "object",
      "required": ["id", "locator", "fact_posture", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 },
        "fact_posture": { "$ref": "#/$defs/fact_posture_enum" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string" },
        "status": {
          "enum": ["pending", "passed", "failed", "not_required"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
